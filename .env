# ─────────────────────────────────────────────────────────────────────────────
# Observability Stack — Environment Variables
#
# Docker Compose automatically loads this file.
# For AWS ECS: inject these via SSM Parameter Store or Secrets Manager —
# do NOT commit real credentials to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── General ───────────────────────────────────────────────────────────────────
ENVIRONMENT=local

# ── Grafana ───────────────────────────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin
GF_AUTH_ANONYMOUS_ENABLED=false
GF_UNIFIED_ALERTING_ENABLED=true
GF_FEATURE_TOGGLES_ENABLE=traceqlEditor traceToMetrics metricsSummary correlations lokiQuerySplitting exploreLogsAggregatedMetrics
